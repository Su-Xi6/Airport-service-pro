
const express = require('express');
const mysql = require('mysql2/promise');
const cors = require('cors');
const path = require('path');
const app = express();
const port = 3000;

// 解析 JSON 请求体
app.use(express.json());

// 启用 CORS 中间件，允许所有来源跨域请求（开发方便）
app.use(cors());

// 服务静态文件（绝对路径，确保从repo根目录 public 目录读文件）
const staticDir = path.join(__dirname, '..', 'public');
app.use(express.static(staticDir));

// 根路径兜底 index.html
app.get('/', (req, res) => {
    res.sendFile(path.join(staticDir, 'index.html'));
});

// 创建 MySQL 连接池
const pool =mysql.createPool({
    host: 'localhost',
    user: 'project_user',          // 你的数据库用户名
    password: 'Airport123!',       // 你的数据库密码（一定要改成正确的）
    database: 'airport_db',        // 数据库名
    waitForConnections: true,
    connectionLimit: 10,           // 最多同时保持 10 个连接
    queueLimit: 0                  // 连接数超过限制时不排队，直接报错
});

// ---------- 1. POST /api/log ----------
app.post('/api/log', async (req, res) => {
    console.log('req.body:', req.body);
    const { module, level, message } = req.body || {};
    // 校验必要字段
    if (!module || !message) {
        return res.status(400).json({ error: '缺少必要字段' });
    }
    try {
        // 插入日志到 system_logs 表
        const sql = 'INSERT INTO system_logs (module, level, message) VALUES (?, ?, ?)';
        const [result] = await pool.execute(sql, [module, level || 'info', message]);
        res.json({ success: true, id: result.insertId });
    } catch (error) {
        console.error('日志写入失败:', error);
        res.status(500).json({ error: '服务器内部错误' });
    }
});

// ---------- 2. GET /api/stats ----------
app.get('/api/stats', async (req, res) => {
    try {
        // 从 passenger_flow 表统计总记录数、总旅客数、平均停留时间
        const [rows] = await pool.query(`
            SELECT 
                COUNT(*) as total_records,
                SUM(passenger_count) as total_passengers,
                AVG(avg_dwell_time) as avg_dwell_time_seconds
            FROM passenger_flow
        `);
        res.json({ success: true, data: rows[0] });
    } catch (error) {
        console.error('获取统计失败:', error);
        res.status(500).json({ error: '服务器内部错误' });
    }
});

// ---------- 3. GET /api/logs?type=attack ----------
app.get('/api/logs', async (req, res) => {
    const logType = req.query.type;
    if (logType !== 'attack') {
        return res.status(400).json({ error: '目前仅支持 type=attack 的查询' });
    }
    try {
        // 从 attack_log 表获取最近 100 条攻击日志，按时间倒序
        const sql = 'SELECT id, attack_type, src_ip, dst_ip, create_time FROM attack_log ORDER BY create_time DESC LIMIT 100';
        const [rows] = await pool.query(sql);
        res.json({ success: true, data: rows });
    } catch (error) {
        console.error('获取攻击日志失败:', error);
        res.status(500).json({ error: '服务器内部错误' });
    }
});

// ---------- 4. GET /api/hourly-stats ----------
app.get('/api/hourly-stats', async (req, res) => {
    try {
        // 查询最近 24 小时，按小时分组，汇总每个小时的 passenger_count
        const sql = `
            SELECT 
                DATE_FORMAT(start_time, '%Y-%m-%d %H:00') as hour,
                SUM(passenger_count) as \`usage\`
            FROM passenger_flow
            WHERE start_time >= DATE_SUB(NOW(), INTERVAL 24 HOUR)
            GROUP BY hour
            ORDER BY hour
        `;
        const [rows] = await pool.query(sql);
        // 如果查询结果为空，可以返回空数组或模拟数据（这里返回空数组）
        res.json({
            success: true,
            data: rows
        });
    } catch (error) {
        console.error('获取小时统计失败:', error);
        res.status(500).json({ error: '服务器内部错误' });
    }
});
    // 这里是关闭 /api/hourly-stats 路由的注释
    // 启动服务器，监听指定端口
app.listen(port, () => {
    console.log(`✅ API server running at http://localhost:${port}`);
    // 测试数据库连接
    pool.getConnection()
        .then(conn => {
            console.log('✅ Database connected');
            conn.release();   // 释放连接回连接池
        })
        .catch(err => {
            console.error('❌ Database connection failed:', err.message);
        });
});
